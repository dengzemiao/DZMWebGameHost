{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DZMWebGameHost",
  "version": "1.0.4",
  "identifier": "com.dengzemiao.webgamehost",
  "build": {
    "beforeDevCommand": "npm run dev:h5",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:h5",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DZMWebGameHost - 游戏主机服务",
        "width": 520,
        "height": 635,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../game-pages/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
